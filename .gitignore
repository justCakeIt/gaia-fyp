########################################
# Node.js / package managers
########################################
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

########################################
# Environment variables (SECRETS)
########################################
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Keep safe examples/templates tracked
!.env.example
!frontend/.env.example
!env-sample

########################################
# Next.js / frontend build output
########################################
.next/
frontend/.next/
out/
frontend/out/
.turbo/
frontend/.turbo/
.vercel/
frontend/.vercel/

########################################
# TypeScript / build metadata
########################################
*.tsbuildinfo
frontend/*.tsbuildinfo
tsconfig.tsbuildinfo
frontend/tsconfig.tsbuildinfo

########################################
# Logs
########################################
logs/
*.log

########################################
# OS files
########################################
.DS_Store
Thumbs.db

########################################
# VS Code
########################################
.vscode/*
!.vscode/extensions.json

########################################
# Claude Code local config
########################################
.claude/

########################################
# Docker
########################################
docker-compose.override.yml

########################################
# MySQL / Database runtime files
# IMPORTANT: Never commit database storage
########################################

# Local DB folder (created accidentally earlier)
db/
db/*

# Docker named volume data
mysql_data/

# MySQL internal/runtime files
*.ibd
*.frm
*.MYD
*.MYI
*.pem
*.pid
*.err
*.sock

# MySQL system schemas (auto-generated)
performance_schema/
mysql/
sys/

########################################
# Build / temp files
########################################
dist/
build/
tmp/
temp/
.cache/
.eslintcache

########################################
# Coverage / testing
########################################
coverage/
frontend/coverage/
.nyc_output/

########################################
# Misc editor temp files
########################################
*.swp
*.swo